{
  "permissions": {
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf C:*)",
      "Bash(format *)",
      "Bash(mkfs*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D *)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/id_rsa*)",
      "Write(**/.ssh/**)",
      "Edit(**/.ssh/**)",
      "Write(**/credentials*)",
      "Edit(**/credentials*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('os').homedir()+'/.claude/hooks/block-destructive.js')\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('os').homedir()+'/.claude/hooks/block-protected.js')\""
          }
        ]
      },
      {
        "matcher": "Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('os').homedir()+'/.claude/hooks/auto-approve-read.js')\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('os').homedir()+'/.claude/hooks/auto-tsc.js')\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('os').homedir()+'/.claude/hooks/session-context.js')\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node -e \"require(require('os').homedir()+'/.claude/scripts/levis-usage-dump.js')\"",
    "padding": 0
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
