{
  "permissions": {
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf C:*)",
      "Bash(format *)",
      "Bash(mkfs*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D *)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/id_rsa*)",
      "Write(**/.ssh/**)",
      "Edit(**/.ssh/**)",
      "Write(**/credentials*)",
      "Edit(**/credentials*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/levingerm/.claude/hooks/block-destructive.js"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/levingerm/.claude/hooks/block-protected.js"
          }
        ]
      },
      {
        "matcher": "Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/levingerm/.claude/hooks/auto-approve-read.js"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/levingerm/.claude/hooks/track-agents.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/levingerm/.claude/hooks/auto-tsc.js"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/levingerm/.claude/hooks/track-agents.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/levingerm/.claude/hooks/session-context.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/levingerm/.claude/hooks/detect-triggers.js"
          }
        ]
      }
    ]
  },
  "claudeMdExcludes": [
    "**/node_modules/**/CLAUDE.md",
    "**/.claude/plugins/cache/**/CLAUDE.md",
    "**/.claude/skills/trailofbits/CLAUDE.md"
  ],
  "statusLine": {
    "type": "command",
    "command": "node \"C:\\Users\\levingerm\\.claude\\scripts\\levis-usage-dump.js\"",
    "padding": 0
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "autoUpdatesChannel": "latest"
}
